# Copy this to .env.local and fill in your values
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — create a free project at https://supabase.com
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Model overrides (optional — defaults shown below)
# Orchestrator: campaign skeleton design + quality check
ORCHESTRATOR_MODEL=claude-opus-4-6

# Chapter + NPC agents: parallel content writers
AGENT_MODEL=claude-sonnet-4-6

# Appendix + DM guide: high-volume reference writing
NANO_MODEL=claude-haiku-4-5-20251001
