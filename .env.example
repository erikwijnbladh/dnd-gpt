# Copy this to .env.local and fill in your values
OPENAI_API_KEY=sk-...

# Supabase — create a free project at https://supabase.com
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Orchestrator — campaign skeleton + quality check
# gpt-5.4: $2.50/1M in, $15/1M out, 1M context
ORCHESTRATOR_MODEL=gpt-5.4

# Chapter + NPC sub-agents — parallel writing (described as "for subagents")
# gpt-5.4-mini: $0.75/1M in, $4.50/1M out
AGENT_MODEL=gpt-5.4-mini

# Appendix agent — high-volume reference/mechanical writing (cheapest)
# gpt-5.4-nano: $0.20/1M in, $1.25/1M out
NANO_MODEL=gpt-5.4-nano
